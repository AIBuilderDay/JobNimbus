GOOGLE_MAPS_API_KEY=op://AIBuilderDay/google-maps-api-key/credential
ANTHROPIC_API_KEY=op://AIBuilderDay/claude-api-key/credential
REPLICATE_API_TOKEN=op://AIBuilderDay/replicate_api_token/credential

# EagleView OAuth2 client credentials. Provider exchanges these for a 24h
# bearer token at runtime (see backend/providers/eagleview.py).
EAGLEVIEW_CLIENT_ID=op://AIBuilderDay/eagleview-client-id/credential
EAGLEVIEW_CLIENT_SECRET=op://AIBuilderDay/eagleview-client-secret/credential
# Sandbox while we're using a developer-tier app. Flip to https://api.eagleview.com once we have prod creds.
EAGLEVIEW_BASE_URL=https://sandbox.apicenter.eagleview.com

RESEND_API_KEY=op://AIBuilderDay/jobnimbus-resend-api-key/credential
